PORT=3001

# Direct Supabase connection — %-encode any @ in the password
DATABASE_URL="postgresql://postgres:<password>@db.<project>.supabase.co:5432/postgres?schema=public&sslmode=require"

# For prisma migrate / db push — usually the same as DATABASE_URL unless using a pooler
DIRECT_URL="postgresql://postgres:<password>@db.<project>.supabase.co:5432/postgres?schema=public&sslmode=require"

JWT_SECRET=
SUPABASE_URL=https://<project>.supabase.co
SUPABASE_SERVICE_KEY=
