generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// Users are owned by Supabase Auth — we store only attempt records here.
// userId holds the Supabase UUID from the verified JWT.
model ScenarioAttempt {
  id          String   @id @default(cuid())
  userId      String   @map("user_id")
  scenarioId  String   @map("scenario_id")
  passed      Boolean
  score       Int      @default(0)
  timeSeconds Int      @default(0) @map("time_seconds")
  completedAt DateTime @default(now()) @map("completed_at")

  @@index([userId])
  @@index([scenarioId])
  @@map("scenario_attempts")
}
