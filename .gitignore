# ── Dependencies ────────────────────────────────────────────────────────────────
node_modules/

# ── Build output ────────────────────────────────────────────────────────────────
dist/
apps/web/dist/
apps/api/dist/
*.tsbuildinfo

# ── Environment variables ────────────────────────────────────────────────────────
# Root-level
.env
.env.local
.env.*.local

# App-specific (explicit, belt-and-suspenders)
apps/api/.env
apps/api/.env.local
apps/api/.env.*.local
apps/web/.env.local
apps/web/.env.*.local

# Allow example templates to be committed
!.env.example
!apps/api/.env.example
!apps/web/.env.example

# ── Logs ────────────────────────────────────────────────────────────────────────
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# ── OS & editor ─────────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
.idea/
*.suo
*.user

# ── Vite ────────────────────────────────────────────────────────────────────────
.vite/
vite.config.ts.timestamp-*

# ── Test coverage ────────────────────────────────────────────────────────────────
coverage/
.nyc_output/

# ── Misc tooling ─────────────────────────────────────────────────────────────────
.eslintcache
.stylelintcache
.parcel-cache
.cache/
